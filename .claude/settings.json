{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "includeCoAuthoredBy": false,
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/auto-push.sh",
            "timeout": 60,
            "statusMessage": "Auto-pushing to GitHub..."
          }
        ]
      }
    ]
  }
}
